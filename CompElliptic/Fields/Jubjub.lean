    refine .split [2 ^ 3, 3 ^ 2, 6566909, 431305263804409] (fun r hr => ?_) (by norm_num)
    simp at hr
    rcases hr with hr | hr | hr | hr
    all_goals rw [hr]
    · exact .prime 2 3 _ (by pratt) (by reduce_mod_char; decide) (by norm_num)
