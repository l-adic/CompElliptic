        refine .split [2, 3, 5, 457, 187256983] (fun r hr => ?_) (by norm_num)
        simp at hr
        rcases hr with hr | hr | hr | hr | hr
        all_goals rw [hr]
        · exact .prime 2 1 _ (by pratt) (by reduce_mod_char; decide) (by norm_num)
        · exact .prime 3 1 _ (by pratt) (by reduce_mod_char; decide) (by norm_num)
        · exact .prime 5 1 _ (by pratt) (by reduce_mod_char; decide) (by norm_num)
        · exact .prime 457 1 _ (by pratt) (by reduce_mod_char; decide) (by norm_num)
        · exact .prime 187256983 1 _ (by pratt) (by reduce_mod_char; decide) (by norm_num)
  · refine .prime 255074062430788457494141376149 1 _ ?_ (by reduce_mod_char; decide) (by norm_num)
    refine PrattCertificate'.out (p := 255074062430788457494141376149) ⟨2, (by reduce_mod_char), ?_⟩
    refine .split [2 ^ 2, 3, 311, 5521, 19861, 623312455501769069] (fun r hr => ?_) (by norm_num)
